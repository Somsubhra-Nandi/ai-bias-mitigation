# ── GitHub Models PAT ───────────────────────────────────────
GITHUB_PAT=ghp_your_token_here

# ── Google Cloud Credentials (Optional) ─────────────────────
# If you used `gcloud auth application-default login`, you don't need this line. 
# But if you downloaded a Service Account JSON key, uncomment and set the path:
# GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\your\sa-key.json"